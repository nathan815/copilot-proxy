# Proxy auth token (required — generated by: .\copilotproxy.ps1 token)
# All API requests must include: Authorization: Bearer <token>
PROXY_AUTH_TOKEN=

# Tailscale auth key (optional — leave empty for interactive browser login)
# TS_AUTHKEY=tskey-auth-xxxx

# Tailscale hostname (optional, defaults to "copilot-proxy")
TS_HOSTNAME=copilot-proxy
