{
	admin off
}

:4141 {
	# Strip ALL CORS headers from upstream to prevent browser-based token theft.
	header {
		-Access-Control-Allow-Origin
		-Access-Control-Allow-Methods
		-Access-Control-Allow-Headers
		-Access-Control-Allow-Credentials
		-Access-Control-Expose-Headers
		-Access-Control-Max-Age
	}

	# Reject CORS preflight requests
	@preflight method OPTIONS
	respond @preflight 204

	# No auth: health check only
	@noauth path /health
	handle @noauth {
		reverse_proxy {$PROXY_UPSTREAM:copilot-proxy:4141}
	}

	# /setup: static HTML instructions page (always available)
	handle /setup {
		root * /srv
		rewrite * /setup.html
		file_server
	}

	# /setup.sh: proxy to approval server (only when running)
	handle /setup.sh {
		reverse_proxy {$SETUP_UPSTREAM:setup-server:4143}
	}

	# Basic auth: UI, models, history, websocket, API status
	@uiroutes path /ui /ui/* /history /history/* /api/* /models /ws /favicon.ico
	handle @uiroutes {
		basic_auth {
			admin {$UI_PASSWORD_HASH}
		}
		reverse_proxy {$PROXY_UPSTREAM:copilot-proxy:4141}
	}

	# Everything else: require Bearer token, then proxy
	handle {
		@notoken not header Authorization "Bearer {$PROXY_AUTH_TOKEN}"
		respond @notoken "Unauthorized" 401
		reverse_proxy {$PROXY_UPSTREAM:copilot-proxy:4141}
	}
}
